{
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "agent",
            "agent": "nn-capture",
            "statusMessage": "Reviewing session for notes worth capturing...",
            "timeout": 120
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "agent",
            "agent": "nn-reload-protocols",
            "statusMessage": "Reloading global protocols after compaction...",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/load-protocols.sh\"",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/protocols-reminder.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
