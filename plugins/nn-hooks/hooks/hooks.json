{
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "agent",
            "agent": "nn-capture",
            "statusMessage": "Reviewing session for notes worth capturing...",
            "timeout": 120
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "agent",
            "agent": "nn-reload-protocols",
            "statusMessage": "Reloading global protocols after compaction...",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/share/nn/plugins/nn-hooks/scripts/load-protocols.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/share/nn/plugins/nn-hooks/scripts/protocols-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
